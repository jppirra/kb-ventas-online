# ============================================================================
# Template — Environment Variables
# Copy to .env and complete before running.
# NEVER commit .env
# ============================================================================

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/my_app
DB_USERNAME=postgres
DB_PASSWORD=                          # REQUIRED

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=                           # REQUIRED — generate: openssl rand -hex 64
JWT_EXPIRATION=3600000                # 1 hour
JWT_REFRESH_EXPIRATION=604800000      # 7 days

# ── Application ──────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173    # frontend URL — used in email links
CORS_ORIGINS=http://localhost:5173

# ── Email (Resend REST API) ──────────────────────────────────────────────────
RESEND_API_KEY=                       # get at resend.com
MAIL_FROM_ADDRESS=onboarding@resend.dev  # use your verified domain in prod

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Admin ────────────────────────────────────────────────────────────────────
APP_ADMIN_EMAIL=

# ── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co  # Project URL from Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # Service role key (Settings > API)
SUPABASE_BUCKET=catalog-images         # Create this bucket in Storage tab

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # https://console.anthropic.com

# ── Gemini AI (proveedor principal, gratis) ───────────────────────────────────
GEMINI_API_KEY=AIza...                 # https://aistudio.google.com/apikey

# ── OpenRouter AI (fallback gratuito) ────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...           # https://openrouter.ai/keys

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api
VITE_GOOGLE_CLIENT_ID=
