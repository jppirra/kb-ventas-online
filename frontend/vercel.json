{
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/mercato", "destination": "/mercato/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://catalogia-backend.onrender.com/api/:path*" },
    { "source": "/((?!.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}
